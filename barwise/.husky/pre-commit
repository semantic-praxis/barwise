cd barwise

# 0. Validate the beads tracker when it is part of this commit. This guards
#    the cross-branch clobber (REPO_REVIEW-2026-06-23 F6) even without the bd
#    binary: --strict makes a non-canonical line an error, not a warning.
#    Runs first so a corrupt tracker fails fast, before build/test. Paths from
#    `git diff` are repo-root-relative regardless of the cd above.
if git diff --cached --name-only | grep -qx '.beads/issues.jsonl'; then
  echo "pre-commit: validating .beads/issues.jsonl ..."
  if ! bash scripts/check-beads.sh --strict; then
    echo "pre-commit: .beads/issues.jsonl failed validation (see above)." >&2
    echo "  Fix the errors, or stage a canonical version (ideally written by bd)." >&2
    exit 1
  fi
fi

# 1. Lint staged files (dprint, eslint, oxlint).
npx lint-staged

# 2. Build all packages to catch cross-package type errors.
#    Turbo caches unchanged packages, so this is fast (~1s) in the
#    common case and ~3s on a full rebuild.
npm run build

# 3. Run tests in packages affected by uncommitted changes.
#    The ...[HEAD] filter selects changed packages and their dependents.
npx turbo run test --filter='...[HEAD]'

# Chain beads hook if bd is available.
if command -v bd >/dev/null 2>&1; then
  bd hooks run pre-commit "$@"
fi
