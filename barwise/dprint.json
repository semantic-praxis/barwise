{
  "typescript": {
    "quoteStyle": "preferDouble",
    "semiColons": "always",
    "trailingCommas": "onlyMultiLine",
    "useTabs": false,
    "indentWidth": 2,
    "lineWidth": 100
  },
  "json": {
    "indentWidth": 2,
    "useTabs": false
  },
  "markdown": {
    "lineWidth": 80
  },
  "excludes": [
    "**/node_modules",
    "**/dist",
    "**/.turbo",
    "**/coverage",
    "**/*.orm.yaml",
    "**/*.map.yaml",
    "**/*.orm-project.yaml",
    "**/package-lock.json",
    "**/schemas/**",
    "test-plan/**"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.93.4.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm"
  ]
}
