{
  "name": "@barwise/core",
  "version": "1.6.1",
  "private": true,
  "description": "Platform-independent ORM 2 metamodel, validation, and verbalization",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./annotation": {
      "types": "./dist/annotation/index.d.ts",
      "default": "./dist/annotation/index.js"
    },
    "./counterexample": {
      "types": "./dist/counterexample/index.d.ts",
      "default": "./dist/counterexample/index.js"
    },
    "./describe": {
      "types": "./dist/describe/index.d.ts",
      "default": "./dist/describe/index.js"
    },
    "./diff": {
      "types": "./dist/diff/index.d.ts",
      "default": "./dist/diff/index.js"
    },
    "./lineage": {
      "types": "./dist/lineage/index.d.ts",
      "default": "./dist/lineage/index.js"
    },
    "./mapping": {
      "types": "./dist/mapping/index.d.ts",
      "default": "./dist/mapping/index.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "default": "./dist/query/index.js"
    },
    "./sql": {
      "types": "./dist/sql/index.d.ts",
      "default": "./dist/sql/index.js"
    },
    "./verbalization": {
      "types": "./dist/verbalization/index.d.ts",
      "default": "./dist/verbalization/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "yaml": "^2.8.2"
  }
}
