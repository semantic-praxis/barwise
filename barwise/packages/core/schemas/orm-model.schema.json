{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orm-modeler.dev/schemas/v1/orm-model.schema.json",
  "title": "ORM Domain Model",
  "description": "Schema for .orm.yaml domain model files used by Barwise.",
  "type": "object",
  "required": ["orm_version", "model"],
  "additionalProperties": false,
  "properties": {
    "orm_version": {
      "type": "string",
      "const": "1.1",
      "description": "Schema version. Must be \"1.1\" for this schema revision."
    },
    "model": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this domain model."
        },
        "domain_context": {
          "type": "string",
          "minLength": 1,
          "description": "The bounded context this model represents (e.g. \"ecommerce\")."
        },
        "note": {
          "type": "string",
          "description": "Free-text model-level note, distinct from formal definitions."
        },
        "object_types": {
          "type": "array",
          "items": { "$ref": "#/definitions/object_type" },
          "description": "The object types (entity and value types) in this model."
        },
        "fact_types": {
          "type": "array",
          "items": { "$ref": "#/definitions/fact_type" },
          "description": "The fact types (relationships) in this model."
        },
        "subtype_facts": {
          "type": "array",
          "items": { "$ref": "#/definitions/subtype_fact" },
          "description": "Subtype relationships between entity types."
        },
        "objectified_fact_types": {
          "type": "array",
          "items": { "$ref": "#/definitions/objectified_fact_type" },
          "description": "Fact types that are simultaneously entity types (objectification/nesting)."
        },
        "populations": {
          "type": "array",
          "items": { "$ref": "#/definitions/population" },
          "description": "Sample fact instance populations used for constraint validation."
        },
        "definitions": {
          "type": "array",
          "items": { "$ref": "#/definitions/definition" },
          "description": "Ubiquitous language entries not directly attached to a model element."
        },
        "diagrams": {
          "type": "array",
          "items": { "$ref": "#/definitions/diagram_layout" },
          "description": "Persisted diagram layouts with element positions and fact type orientations."
        }
      }
    }
  },
  "definitions": {
    "object_type": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier (UUID)."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name."
        },
        "kind": {
          "type": "string",
          "enum": ["entity", "value"],
          "description": "Whether this is an entity type or a value type."
        },
        "reference_mode": {
          "type": "string",
          "minLength": 1,
          "description": "The reference mode for entity types (e.g. \"customer_id\"). Required for entity types."
        },
        "definition": {
          "type": "string",
          "description": "Natural-language definition for the ubiquitous language."
        },
        "source_context": {
          "type": "string",
          "description": "The bounded context this object type originates from."
        },
        "value_constraint": {
          "$ref": "#/definitions/value_constraint_def",
          "description": "Value constraint for value types."
        },
        "data_type": {
          "$ref": "#/definitions/data_type_def",
          "description": "Conceptual data type for value types (e.g. text, integer, decimal)."
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Alternative names for this object type (synonyms from different stakeholders or contexts)."
        },
        "independent": {
          "type": "boolean",
          "description": "Whether the object type is independent: its instances may exist without participating in any non-identifying fact."
        },
        "default_value": {
          "type": "string",
          "description": "Default value for a value type, threaded into relational mapping as a SQL column DEFAULT."
        },
        "note": {
          "type": "string",
          "description": "Free-text note, informal commentary distinct from the formal definition."
        }
      },
      "if": {
        "properties": { "kind": { "const": "entity" } }
      },
      "then": {
        "required": ["reference_mode"]
      }
    },
    "value_range_def": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": { "type": "string", "description": "Lower bound; omit for open-below." },
        "max": { "type": "string", "description": "Upper bound; omit for open-above." },
        "min_inclusive": { "type": "boolean", "description": "Lower bound inclusive (default true)." },
        "max_inclusive": { "type": "boolean", "description": "Upper bound inclusive (default true)." }
      },
      "anyOf": [{ "required": ["min"] }, { "required": ["max"] }]
    },
    "value_constraint_def": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "values": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Enumerated allowed values."
        },
        "ranges": {
          "type": "array",
          "items": { "$ref": "#/definitions/value_range_def" },
          "minItems": 1,
          "description": "Allowed value ranges (inclusive/exclusive, possibly open-ended)."
        }
      },
      "anyOf": [{ "required": ["values"] }, { "required": ["ranges"] }]
    },
    "data_type_def": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "enum": ["text", "integer", "decimal", "money", "float", "boolean", "date", "time", "datetime", "timestamp", "auto_counter", "binary", "uuid", "other"],
          "description": "Portable conceptual data type name."
        },
        "length": {
          "type": "integer",
          "minimum": 0,
          "description": "Length parameter (e.g. VARCHAR length)."
        },
        "scale": {
          "type": "integer",
          "minimum": 0,
          "description": "Scale parameter (e.g. decimal scale)."
        }
      }
    },
    "role": {
      "type": "object",
      "required": ["id", "player", "role_name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier for this role."
        },
        "player": {
          "type": "string",
          "minLength": 1,
          "description": "The id of the ObjectType that plays this role."
        },
        "role_name": {
          "type": "string",
          "minLength": 1,
          "description": "The role name used in verbalization."
        }
      }
    },
    "constraint": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type": { "const": "internal_uniqueness" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "description": "Role ids within the same fact type."
            },
            "is_preferred": {
              "type": "boolean",
              "description": "True if this uniqueness constraint is the preferred identifier for the entity type."
            }
          },
          "required": ["type", "roles"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "mandatory" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "role": {
              "type": "string",
              "minLength": 1,
              "description": "The single role id that is mandatory."
            }
          },
          "required": ["type", "role"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "external_uniqueness" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "description": "Role ids spanning multiple fact types."
            }
          },
          "required": ["type", "roles"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "value_constraint" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "role": {
              "type": "string",
              "minLength": 1,
              "description": "The role id this constraint applies to."
            },
            "values": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1,
              "description": "Allowed enumerated values."
            },
            "ranges": {
              "type": "array",
              "items": { "$ref": "#/definitions/value_range_def" },
              "minItems": 1,
              "description": "Allowed value ranges (inclusive/exclusive, possibly open-ended)."
            }
          },
          "required": ["type"],
          "anyOf": [{ "required": ["values"] }, { "required": ["ranges"] }],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "disjunctive_mandatory" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 2,
              "description": "Two or more role ids (may span fact types)."
            }
          },
          "required": ["type", "roles"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "exclusion" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 2,
              "description": "Two or more role ids (may span fact types)."
            }
          },
          "required": ["type", "roles"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "exclusive_or" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 2,
              "description": "Two or more role ids (may span fact types)."
            }
          },
          "required": ["type", "roles"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "subset" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "subset_roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "description": "Role ids forming the subset side."
            },
            "superset_roles": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "description": "Role ids forming the superset side."
            }
          },
          "required": ["type", "subset_roles", "superset_roles"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "equality" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "roles_1": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "description": "First role sequence."
            },
            "roles_2": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1,
              "description": "Second role sequence."
            }
          },
          "required": ["type", "roles_1", "roles_2"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "ring" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "role_1": {
              "type": "string",
              "minLength": 1,
              "description": "First role id."
            },
            "role_2": {
              "type": "string",
              "minLength": 1,
              "description": "Second role id."
            },
            "ring_type": {
              "type": "string",
              "enum": ["irreflexive", "asymmetric", "antisymmetric", "intransitive", "acyclic", "symmetric", "transitive", "purely_reflexive"],
              "description": "The ring property being constrained."
            }
          },
          "required": ["type", "role_1", "role_2", "ring_type"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "frequency" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "role": {
              "type": "string",
              "minLength": 1,
              "description": "The role being frequency-constrained."
            },
            "min": {
              "type": "integer",
              "minimum": 1,
              "description": "Minimum occurrences."
            },
            "max": {
              "oneOf": [
                { "type": "integer", "minimum": 1 },
                { "type": "string", "const": "unbounded" }
              ],
              "description": "Maximum occurrences, or \"unbounded\"."
            }
          },
          "required": ["type", "role", "min", "max"],
          "additionalProperties": false
        },
        {
          "properties": {
            "type": { "const": "value_comparison" },
            "id": {
              "type": "string",
              "description": "Unique identifier for constraint traceability."
            },
            "modality": {
              "type": "string",
              "enum": ["alethic", "deontic"],
              "description": "Alethic (necessity, the default) or deontic (obligation)."
            },
            "role_1": {
              "type": "string",
              "minLength": 1,
              "description": "Left-hand role id."
            },
            "role_2": {
              "type": "string",
              "minLength": 1,
              "description": "Right-hand role id."
            },
            "operator": {
              "type": "string",
              "enum": ["<", "<=", "=", "<>", ">=", ">"],
              "description": "value(role_1) <operator> value(role_2) must hold for every instance."
            }
          },
          "required": ["type", "role_1", "role_2", "operator"],
          "additionalProperties": false
        }
      ]
    },
    "fact_type": {
      "type": "object",
      "required": ["id", "name", "roles", "readings"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name (typically the forward reading)."
        },
        "definition": {
          "type": "string",
          "description": "Natural-language definition."
        },
        "note": {
          "type": "string",
          "description": "Free-text note, informal commentary distinct from the formal definition."
        },
        "roles": {
          "type": "array",
          "items": { "$ref": "#/definitions/role" },
          "minItems": 1,
          "description": "Ordered roles in this fact type."
        },
        "readings": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "description": "Reading templates with positional placeholders."
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/definitions/constraint" },
          "description": "Constraints on this fact type."
        }
      }
    },
    "subtype_fact": {
      "type": "object",
      "required": ["id", "subtype", "supertype"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier."
        },
        "subtype": {
          "type": "string",
          "minLength": 1,
          "description": "The id of the subtype (child) entity type."
        },
        "supertype": {
          "type": "string",
          "minLength": 1,
          "description": "The id of the supertype (parent) entity type."
        },
        "provides_identification": {
          "type": "boolean",
          "default": true,
          "description": "Whether the subtype uses the supertype's reference scheme for identification."
        },
        "is_exclusive": {
          "type": "boolean",
          "default": false,
          "description": "Whether the subtypes of this supertype are mutually exclusive. When true, no supertype instance can be an instance of more than one subtype in the partition group."
        },
        "is_exhaustive": {
          "type": "boolean",
          "default": false,
          "description": "Whether the subtypes of this supertype are exhaustive (cover all instances). When true, every supertype instance must be an instance of at least one subtype in the partition group."
        }
      }
    },
    "objectified_fact_type": {
      "type": "object",
      "required": ["id", "fact_type", "object_type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier."
        },
        "fact_type": {
          "type": "string",
          "minLength": 1,
          "description": "The id of the fact type being objectified."
        },
        "object_type": {
          "type": "string",
          "minLength": 1,
          "description": "The id of the entity type created by objectification."
        }
      }
    },
    "population": {
      "type": "object",
      "required": ["id", "fact_type", "instances"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier."
        },
        "fact_type": {
          "type": "string",
          "minLength": 1,
          "description": "The id of the fact type this population samples."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this population."
        },
        "instances": {
          "type": "array",
          "items": { "$ref": "#/definitions/fact_instance" },
          "description": "The sample fact instances in this population."
        }
      }
    },
    "fact_instance": {
      "type": "object",
      "required": ["id", "role_values"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier for this instance."
        },
        "role_values": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Mapping of role id to concrete value."
        }
      }
    },
    "definition": {
      "type": "object",
      "required": ["term", "definition"],
      "additionalProperties": false,
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1,
          "description": "The term being defined."
        },
        "definition": {
          "type": "string",
          "minLength": 1,
          "description": "The natural-language definition."
        },
        "context": {
          "type": "string",
          "description": "The bounded context in which this term applies."
        }
      }
    },
    "diagram_layout": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name for this diagram view."
        },
        "elements": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Object type names included in this view. When absent, all elements are shown."
        },
        "positions": {
          "type": "object",
          "description": "Entity type positions keyed by element name. Values are {x, y} in integer pixels, screen coordinates (0,0 top-left, x right, y down).",
          "additionalProperties": {
            "type": "object",
            "required": ["x", "y"],
            "additionalProperties": false,
            "properties": {
              "x": { "type": "integer", "description": "Horizontal position in pixels." },
              "y": { "type": "integer", "description": "Vertical position in pixels." }
            }
          }
        },
        "orientations": {
          "type": "object",
          "description": "Fact type orientation overrides keyed by fact type name. Only includes explicitly set orientations.",
          "additionalProperties": {
            "type": "string",
            "enum": ["horizontal", "vertical"]
          }
        }
      }
    }
  }
}
