{
  "name": "@barwise/diagram-ui",
  "version": "1.5.0",
  "private": true,
  "description": "React renderer for ORM diagrams: interactive canvas and (WS3) headless SVG",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest watch",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@barwise/diagram": "1.5.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.12",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
