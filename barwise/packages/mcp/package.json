{
  "name": "@barwise/mcp",
  "version": "1.5.0",
  "private": true,
  "description": "MCP server for ORM 2 modeling capabilities",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "bin": {
    "barwise-mcp": "./dist/bundle/index.cjs"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabeschenz/barwise.git",
    "directory": "barwise/packages/mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ORM",
    "Object-Role Modeling",
    "data modeling",
    "conceptual modeling"
  ],
  "license": "SEE LICENSE IN ../../LICENSE",
  "author": "Gabe Schenz",
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.mjs",
    "prepublishOnly": "node esbuild.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@barwise/code-analysis": "1.5.0",
    "@barwise/core": "1.5.0",
    "@barwise/dbt": "1.5.0",
    "@barwise/diagram": "1.5.0",
    "@barwise/diagram-ui": "1.5.0",
    "@barwise/formats": "1.5.0",
    "@barwise/llm": "1.5.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.3",
    "vitest": "^3.0.0"
  }
}
