{
  "name": "@barwise/cli",
  "version": "1.6.0",
  "private": true,
  "description": "CLI tool for ORM 2 modeling",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "barwise": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "node esbuild.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@barwise/code-analysis": "1.6.0",
    "@barwise/core": "1.6.0",
    "@barwise/dbt": "1.6.0",
    "@barwise/diagram": "1.6.0",
    "@barwise/diagram-ui": "1.6.0",
    "@barwise/formats": "1.6.0",
    "@barwise/llm": "1.6.0",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.27.3",
    "vitest": "^3.0.0"
  }
}
