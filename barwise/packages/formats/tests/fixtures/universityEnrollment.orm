<?xml version="1.0" encoding="utf-8"?>
<!--
  Sample NORMA .orm file with objectified fact types and subtypes.
  Hand-crafted for integration testing. Not generated by NORMA.
-->
<orm:ORM2 xmlns:orm="http://schemas.neumont.edu/ORM/2006-04/ORMCore">
  <orm:ORMModel id="_model2" Name="University Enrollment">
    <orm:Objects>
      <orm:EntityType id="_et_person" Name="Person" _ReferenceMode="Id">
        <orm:PlayedRoles>
          <orm:Role ref="_r_person_mentors" />
          <orm:Role ref="_r_person_mentored" />
        </orm:PlayedRoles>
      </orm:EntityType>
      <orm:EntityType id="_et_student" Name="Student" _ReferenceMode="StudentId">
        <orm:PlayedRoles>
          <orm:Role ref="_r_student_enrolls" />
        </orm:PlayedRoles>
      </orm:EntityType>
      <orm:EntityType id="_et_course" Name="Course" _ReferenceMode="Code">
        <orm:PlayedRoles>
          <orm:Role ref="_r_course_enrolled" />
        </orm:PlayedRoles>
      </orm:EntityType>
      <orm:ObjectifiedType id="_ot_enrollment" Name="Enrollment" _ReferenceMode="">
        <orm:NestedPredicate ref="_ft_enrolls" />
        <orm:PlayedRoles>
          <orm:Role ref="_r_enrollment_has_grade" />
        </orm:PlayedRoles>
      </orm:ObjectifiedType>
      <orm:ValueType id="_vt_grade" Name="Grade">
        <orm:PlayedRoles>
          <orm:Role ref="_r_grade_of_enrollment" />
        </orm:PlayedRoles>
        <orm:ValueRestriction>
          <orm:ValueConstraint>
            <orm:ValueRanges>
              <orm:ValueRange MinValue="A" MaxValue="A" />
              <orm:ValueRange MinValue="B" MaxValue="B" />
              <orm:ValueRange MinValue="C" MaxValue="C" />
              <orm:ValueRange MinValue="D" MaxValue="D" />
              <orm:ValueRange MinValue="F" MaxValue="F" />
            </orm:ValueRanges>
          </orm:ValueConstraint>
        </orm:ValueRestriction>
      </orm:ValueType>
    </orm:Objects>
    <orm:Facts>
      <orm:Fact id="_ft_enrolls" _Name="Student enrolls in Course">
        <orm:FactRoles>
          <orm:Role id="_r_student_enrolls" Name="enrolls in" _IsMandatory="false">
            <orm:RolePlayer ref="_et_student" />
          </orm:Role>
          <orm:Role id="_r_course_enrolled" Name="is enrolled by" _IsMandatory="false">
            <orm:RolePlayer ref="_et_course" />
          </orm:Role>
        </orm:FactRoles>
        <orm:ReadingOrders>
          <orm:ReadingOrder id="_ro_enrolls_1">
            <orm:Readings>
              <orm:Reading id="_rd_enrolls_1">
                <orm:Data>{0} enrolls in {1}</orm:Data>
              </orm:Reading>
            </orm:Readings>
            <orm:RoleSequence>
              <orm:Role ref="_r_student_enrolls" />
              <orm:Role ref="_r_course_enrolled" />
            </orm:RoleSequence>
          </orm:ReadingOrder>
        </orm:ReadingOrders>
        <orm:InternalConstraints>
          <orm:UniquenessConstraint ref="_uc_enrollment" />
        </orm:InternalConstraints>
      </orm:Fact>
      <orm:Fact id="_ft_has_grade" _Name="Enrollment has Grade">
        <orm:FactRoles>
          <orm:Role id="_r_enrollment_has_grade" Name="has" _IsMandatory="false">
            <orm:RolePlayer ref="_ot_enrollment" />
          </orm:Role>
          <orm:Role id="_r_grade_of_enrollment" Name="is of" _IsMandatory="false">
            <orm:RolePlayer ref="_vt_grade" />
          </orm:Role>
        </orm:FactRoles>
        <orm:ReadingOrders>
          <orm:ReadingOrder id="_ro_has_grade_1">
            <orm:Readings>
              <orm:Reading id="_rd_has_grade_1">
                <orm:Data>{0} has {1}</orm:Data>
              </orm:Reading>
            </orm:Readings>
            <orm:RoleSequence>
              <orm:Role ref="_r_enrollment_has_grade" />
              <orm:Role ref="_r_grade_of_enrollment" />
            </orm:RoleSequence>
          </orm:ReadingOrder>
        </orm:ReadingOrders>
        <orm:InternalConstraints>
          <orm:UniquenessConstraint ref="_uc_enrollment_grade" />
        </orm:InternalConstraints>
      </orm:Fact>
      <orm:Fact id="_ft_mentors" _Name="Person mentors Person">
        <orm:FactRoles>
          <orm:Role id="_r_person_mentors" Name="mentors" _IsMandatory="false">
            <orm:RolePlayer ref="_et_person" />
          </orm:Role>
          <orm:Role id="_r_person_mentored" Name="is mentored by" _IsMandatory="false">
            <orm:RolePlayer ref="_et_person" />
          </orm:Role>
        </orm:FactRoles>
        <orm:ReadingOrders>
          <orm:ReadingOrder id="_ro_mentors_1">
            <orm:Readings>
              <orm:Reading id="_rd_mentors_1">
                <orm:Data>{0} mentors {1}</orm:Data>
              </orm:Reading>
            </orm:Readings>
            <orm:RoleSequence>
              <orm:Role ref="_r_person_mentors" />
              <orm:Role ref="_r_person_mentored" />
            </orm:RoleSequence>
          </orm:ReadingOrder>
        </orm:ReadingOrders>
        <orm:InternalConstraints>
          <orm:RingConstraint ref="_rc_mentors" />
        </orm:InternalConstraints>
      </orm:Fact>
      <!-- Subtype fact: Student is a subtype of Person -->
      <orm:SubtypeFact id="_sf_student_person" PreferredIdentificationPath="true">
        <orm:FactRoles>
          <orm:SubtypeMetaRole id="_sr_student">
            <orm:RolePlayer ref="_et_student" />
          </orm:SubtypeMetaRole>
          <orm:SupertypeMetaRole id="_sr_person">
            <orm:RolePlayer ref="_et_person" />
          </orm:SupertypeMetaRole>
        </orm:FactRoles>
      </orm:SubtypeFact>
    </orm:Facts>
    <orm:Constraints>
      <!-- Spanning uniqueness on enrollment (Student, Course combination) -->
      <orm:UniquenessConstraint id="_uc_enrollment" Name="UC_Enrollment" IsInternal="true" IsPreferred="false">
        <orm:RoleSequence>
          <orm:Role ref="_r_student_enrolls" />
          <orm:Role ref="_r_course_enrolled" />
        </orm:RoleSequence>
      </orm:UniquenessConstraint>
      <!-- Each Enrollment has at most one Grade -->
      <orm:UniquenessConstraint id="_uc_enrollment_grade" Name="UC_EnrollmentGrade" IsInternal="true" IsPreferred="false">
        <orm:RoleSequence>
          <orm:Role ref="_r_enrollment_has_grade" />
        </orm:RoleSequence>
      </orm:UniquenessConstraint>
      <!-- Irreflexive ring: no Person mentors themselves -->
      <orm:RingConstraint id="_rc_mentors" Name="RC_Mentors" Type="Irreflexive">
        <orm:RoleSequence>
          <orm:Role ref="_r_person_mentors" />
          <orm:Role ref="_r_person_mentored" />
        </orm:RoleSequence>
      </orm:RingConstraint>
    </orm:Constraints>
  </orm:ORMModel>
</orm:ORM2>
