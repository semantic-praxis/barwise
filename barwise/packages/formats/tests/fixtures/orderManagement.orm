      </orm:ValueType>
      <orm:ValueType id="_vt_rating" Name="Rating">
        <orm:PlayedRoles>
          <orm:Role ref="_r_rating_val" />
        </orm:PlayedRoles>
        <orm:ValueRestriction>
          <orm:ValueConstraint>
            <orm:ValueRanges>
              <orm:ValueRange MinValue="1" MaxValue="1" />
              <orm:ValueRange MinValue="2" MaxValue="2" />
              <orm:ValueRange MinValue="3" MaxValue="3" />
              <orm:ValueRange MinValue="4" MaxValue="4" />
              <orm:ValueRange MinValue="5" MaxValue="5" />
            </orm:ValueRanges>
          </orm:ValueConstraint>
        </orm:ValueRestriction>
      </orm:ValueType>
    </orm:Objects>
    <orm:Facts>
      <orm:Fact id="_ft_places" _Name="Customer places Order">
        <orm:FactRoles>
          <orm:Role id="_r_cust_places" Name="places" _IsMandatory="false">
            <orm:RolePlayer ref="_et_customer" />
          </orm:Role>
          <orm:Role id="_r_order_placed" Name="is placed by" _IsMandatory="true">
            <orm:RolePlayer ref="_et_order" />
          </orm:Role>
        </orm:FactRoles>
        <orm:ReadingOrders>
          <orm:ReadingOrder id="_ro_places_1">
            <orm:Readings>
              <orm:Reading id="_rd_places_1">
                <orm:Data>{0} places {1}</orm:Data>
              </orm:Reading>
            </orm:Readings>
            <orm:RoleSequence>
              <orm:Role ref="_r_cust_places" />
              <orm:Role ref="_r_order_placed" />
