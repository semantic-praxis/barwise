            </orm:RoleSequence>
          </orm:ReadingOrder>
        </orm:ReadingOrders>
        <orm:InternalConstraints>
          <orm:UniquenessConstraint ref="_uc_cust_name" />
          <orm:MandatoryConstraint ref="_mc_cust_name" />
        </orm:InternalConstraints>
      </orm:Fact>
      <orm:Fact id="_ft_has_date" _Name="Order has Date">
        <orm:FactRoles>
          <orm:Role id="_r_order_has_date" Name="has" _IsMandatory="true">
            <orm:RolePlayer ref="_et_order" />
          </orm:Role>
          <orm:Role id="_r_date_of_order" Name="is of" _IsMandatory="false">
