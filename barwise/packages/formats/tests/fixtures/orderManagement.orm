          </orm:ReadingOrder>
        </orm:ReadingOrders>
        <orm:InternalConstraints>
          <orm:UniquenessConstraint ref="_uc_order_placed" />
          <orm:MandatoryConstraint ref="_mc_order_placed" />
        </orm:InternalConstraints>
      </orm:Fact>
      <orm:Fact id="_ft_has_name" _Name="Customer has Name">
        <orm:FactRoles>
          <orm:Role id="_r_cust_has_name" Name="has" _IsMandatory="true">
            <orm:RolePlayer ref="_et_customer" />
          </orm:Role>
          <orm:Role id="_r_name_of_cust" Name="is of" _IsMandatory="false">
            <orm:RolePlayer ref="_vt_name" />
          </orm:Role>
