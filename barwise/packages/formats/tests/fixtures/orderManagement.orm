        </orm:InternalConstraints>
      </orm:Fact>
    </orm:Facts>
    <orm:Constraints>
      <!-- Each Order is placed by at most one Customer (uniqueness on Order role) -->
      <orm:UniquenessConstraint id="_uc_order_placed" Name="InternalUniquenessConstraint1" IsInternal="true" IsPreferred="false">
        <orm:RoleSequence>
          <orm:Role ref="_r_order_placed" />
        </orm:RoleSequence>
      </orm:UniquenessConstraint>
      <!-- Each Order must be placed by a Customer (mandatory on Order role) -->
      <orm:MandatoryConstraint id="_mc_order_placed" Name="SimpleMandatoryConstraint1" IsSimple="true">
        <orm:RoleSequence>
          <orm:Role ref="_r_order_placed" />
        </orm:RoleSequence>
      </orm:MandatoryConstraint>
      <!-- Each Customer has at most one Name -->
      <orm:UniquenessConstraint id="_uc_cust_name" Name="InternalUniquenessConstraint2" IsInternal="true" IsPreferred="false">
        <orm:RoleSequence>
          <orm:Role ref="_r_cust_has_name" />
        </orm:RoleSequence>
      </orm:UniquenessConstraint>
      <!-- Each Customer must have a Name -->
      <orm:MandatoryConstraint id="_mc_cust_name" Name="SimpleMandatoryConstraint2" IsSimple="true">
        <orm:RoleSequence>
          <orm:Role ref="_r_cust_has_name" />
        </orm:RoleSequence>
      </orm:MandatoryConstraint>
      <!-- Each Order has at most one Date -->
      <orm:UniquenessConstraint id="_uc_order_date" Name="InternalUniquenessConstraint3" IsInternal="true" IsPreferred="false">
        <orm:RoleSequence>
          <orm:Role ref="_r_order_has_date" />
        </orm:RoleSequence>
      </orm:UniquenessConstraint>
      <!-- Each Order must have a Date -->
