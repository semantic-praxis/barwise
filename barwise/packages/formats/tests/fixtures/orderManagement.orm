<orm:ORM2 xmlns:orm="http://schemas.neumont.edu/ORM/2006-04/ORMCore">
  <orm:ORMModel id="_model1" Name="Order Management">
    <orm:Objects>
      <orm:EntityType id="_et_customer" Name="Customer" _ReferenceMode="Id">
