{
  "name": "@barwise/code-analysis",
  "version": "1.5.0",
  "private": true,
  "description": "LSP-based code analysis for ORM model extraction (TypeScript, Java, Kotlin)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@barwise/core": "1.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
